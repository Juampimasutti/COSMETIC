  if(monto<=0) return toast('El monto debe ser mayor a 0.','error');
  const fecha=localISOToISO(document.getElementById('gastoFecha').value);
  state.gastos.push({id:uid(),fecha,desc,categoria:cat,monto,billetera,moneda});
  // Impacta en cashflow como egreso
  state.cashflow.movimientos.push({id:uid(),tipo:'egreso',monto,desc:'Gasto '+cat+(desc?' — '+desc:''),billetera,moneda,fecha,esGasto:true});
  closeModal('modalGasto'); toast('Gasto registrado.','success'); renderPage(currentPage);
}

function eliminarGasto(id) {
  if(!confirm('¿Eliminar este gasto?')) return;
  state.gastos=state.gastos.filter(g=>g.id!==id);
  toast('Gasto eliminado.'); renderPage(currentPage);
}

// ═══════════════════ INIT ═══════════════════
document.getElementById('topbarDate').textContent = new Date().toLocaleDateString('es-AR',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
renderPage('dashboard');

window.addEventListener('resize', () => {
  if (currentPage==='dashboard' && document.getElementById('dashChart')) actualizarComparacion();
});
</script>
</body>
