function guardarAjuste() {
  const id=document.getElementById('ajusteProductoId').value;
  const nq=parseFloat(document.getElementById('ajusteCantidad').value);
  const motivo=document.getElementById('ajusteMotivo').value.trim();
  if(isNaN(nq)||nq<0) return toast('Ingresá una cantidad válida.','error');
  if(!motivo) return toast('Ingresá un motivo.','error');
  const p=state.productos.find(x=>x.id===id);
  const diff=nq-p.cantidad; p.cantidad=nq;
  state.compras.push({id:uid(),fecha:new Date().toISOString(),productoId:id,productoNombre:prodNombre(p),unidades:Math.abs(diff),costoUnitario:p.costoProm,totalEgreso:0,nota:'[AJUSTE] '+motivo,tipo:'ajuste',diff});
  closeModal('modalAjuste');
  toast('Stock ajustado. '+(diff>=0?'+':'')+diff+' unidades.','success');
  renderPage(currentPage);
}

