<script>
// ═══════════════════ STATE ═══════════════════
let state = {
  productos: [],
  ventas: [],
  compras: [],
  cashflow: { movimientos: [], balanceHistory: [] },
  categorias: ['Labial','Base','Sombra','Perfume','Crema','Sérum','Máscara','Delineador','Rubor','Corrector','Bronzer','Iluminador','Otro'],
  gastos: [],
  categoriasGastos: ['Alquiler','Sueldo','Suscripción','Publicidad','Servicios','Transporte','Otro']
};

let currentPage = 'dashboard';

// Dashboard range state
let dashRange = {
  desde: (() => { const d = new Date(); d.setDate(1); return d.toISOString().slice(0,10); })(),
  hasta: new Date().toISOString().slice(0,10),
  preset: 'mes'
};

// ═══════════════════ UTILS ═══════════════════
function uid() { return Date.now().toString(16) + Math.random().toString(16).slice(2,10); }

function fmt(n) {
  if (n === undefined || n === null || isNaN(n)) return '$0';
  return '$' + Math.round(n).toLocaleString('es-AR');
}

function fmtShort(n) {
  if (Math.abs(n) >= 1000000) return '$' + (n/1000000).toFixed(1) + 'M';
  if (Math.abs(n) >= 1000) return '$' + (n/1000).toFixed(0) + 'k';
  return '$' + Math.round(n);
}

function fmtDate(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('es-AR', { day:'2-digit', month:'2-digit', year:'2-digit' });
}

function fmtDatetime(iso) {
  const d = new Date(iso);
  return d.toLocaleDateString('es-AR',{day:'2-digit',month:'2-digit',year:'2-digit'}) + ' ' +
         d.toLocaleTimeString('es-AR',{hour:'2-digit',minute:'2-digit'});
}

function prodNombre(p) {
  return p.marca + ' ' + p.nombre + (p.variante ? ' — ' + p.variante : '');
}

function toast(msg, type='') {
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
function openModal(id)  { document.getElementById(id).classList.remove('hidden'); }

function ventasEnRango(desde, hasta) {
  const d0 = new Date(desde + 'T00:00:00');
  const d1 = new Date(hasta + 'T23:59:59');
  return state.ventas.filter(v => { const d = new Date(v.fecha); return d >= d0 && d <= d1; });
}

function gastosEnRango(desde, hasta) {
  const d0 = new Date(desde + 'T00:00:00');
  const d1 = new Date(hasta + 'T23:59:59');
  return state.gastos.filter(g => { const d = new Date(g.fecha); return d >= d0 && d <= d1; });
}

function fletesEnRango(desde, hasta) {
  const d0 = new Date(desde + 'T00:00:00');
  const d1 = new Date(hasta + 'T23:59:59');
  return state.compras.filter(c => c.tipo==='compra' && c.flete>0 && (() => { const d=new Date(c.fecha); return d>=d0&&d<=d1; })());
}

function nowLocalISO() {
  const now = new Date();
  const local = new Date(now.getTime() - now.getTimezoneOffset() * 60000);
  return local.toISOString().slice(0,16);
}

function localISOToISO(val) {
  return val ? new Date(val).toISOString() : new Date().toISOString();
}

function calcPrevRange(desde, hasta) {
  const d0 = new Date(desde + 'T00:00:00');
  const d1 = new Date(hasta + 'T23:59:59');
  const dias = Math.round((d1 - d0) / 86400000) + 1;
  const prevHasta = new Date(d0); prevHasta.setDate(prevHasta.getDate() - 1);
  const prevDesde = new Date(prevHasta); prevDesde.setDate(prevDesde.getDate() - dias + 1);
  return { desde: prevDesde.toISOString().slice(0,10), hasta: prevHasta.toISOString().slice(0,10) };
}

function deltaHtml(curr, prev) {
  if (prev === 0 && curr === 0) return '';
  const pct = prev === 0 ? 100 : ((curr - prev) / Math.abs(prev) * 100);
  const sign = pct >= 0 ? '+' : '';
  const cls  = pct >= 0 ? 'delta-up' : 'delta-down';
  const arrow = pct >= 0 ? '▲' : '▼';
  return `<span class="stat-delta ${cls}">${arrow} ${sign}${pct.toFixed(0)}%</span>`;
}

// ═══════════════════ NAVIGATION ═══════════════════
function navigate(page) {
  currentPage = page;
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  document.querySelector(`.nav-item[onclick="navigate('${page}')"]`).classList.add('active');
  document.getElementById('topbarTitle').textContent = {dashboard:'Dashboard',productos:'Productos',ventas:'Ventas',compras:'Compras',cashflow:'Cashflow',gastos:'Gastos'}[page];
  renderPage(page);
}

function renderPage(page) {
  ({dashboard:renderDashboard, productos:renderProductos, ventas:renderVentas, compras:renderCompras, cashflow:renderCashflow, gastos:renderGastos})[page](document.getElementById('content'));
}

// ═══════════════════ DASHBOARD ═══════════════════
function setPreset(preset) {
  const hoy = new Date();
  dashRange.preset = preset;
  if (preset === 'hoy') {
    dashRange.desde = dashRange.hasta = hoy.toISOString().slice(0,10);
  } else if (preset === '7d') {
    const d = new Date(hoy); d.setDate(d.getDate()-6);
    dashRange.desde = d.toISOString().slice(0,10);
    dashRange.hasta = hoy.toISOString().slice(0,10);
  } else if (preset === 'mes') {
    dashRange.desde = new Date(hoy.getFullYear(), hoy.getMonth(), 1).toISOString().slice(0,10);
    dashRange.hasta = hoy.toISOString().slice(0,10);
  } else if (preset === '30d') {
    const d = new Date(hoy); d.setDate(d.getDate()-29);
    dashRange.desde = d.toISOString().slice(0,10);
    dashRange.hasta = hoy.toISOString().slice(0,10);
  }
  document.getElementById('dashDesde').value = dashRange.desde;
  document.getElementById('dashHasta').value = dashRange.hasta;
  actualizarComparacion();
}

function onDateChange() {
  dashRange.desde  = document.getElementById('dashDesde').value;
  dashRange.hasta  = document.getElementById('dashHasta').value;
  dashRange.preset = 'custom';
  document.querySelectorAll('.chip[data-preset]').forEach(c => c.classList.remove('active'));
  actualizarComparacion();
}

function actualizarComparacion() {
  document.querySelectorAll('.chip[data-preset]').forEach(c => {
    c.classList.toggle('active', c.dataset.preset === dashRange.preset);
  });

  const curr = ventasEnRango(dashRange.desde, dashRange.hasta);
  const prev = calcPrevRange(dashRange.desde, dashRange.hasta);
  const prevV = ventasEnRango(prev.desde, prev.hasta);

  const cI  = curr.reduce((s,v) => s+v.totalIngreso,   0);
  const cGB = curr.reduce((s,v) => s+v.totalGanancia,  0);
  const cU  = curr.reduce((s,v) => s+v.unidades,       0);
  const pI  = prevV.reduce((s,v) => s+v.totalIngreso,  0);
  const pGB = prevV.reduce((s,v) => s+v.totalGanancia, 0);
  const pU  = prevV.reduce((s,v) => s+v.unidades,      0);

  const currGastos  = gastosEnRango(dashRange.desde, dashRange.hasta);
  const prevGastos  = gastosEnRango(prev.desde, prev.hasta);
  const currFletes  = fletesEnRango(dashRange.desde, dashRange.hasta);
  const prevFletes  = fletesEnRango(prev.desde, prev.hasta);
  const cNeta = cGB - currGastos.reduce((s,g)=>s+g.monto,0) - currFletes.reduce((s,c)=>s+c.flete,0);
  const pNeta = pGB - prevGastos.reduce((s,g)=>s+g.monto,0) - prevFletes.reduce((s,c)=>s+c.flete,0);

  const prevLabel = fmtDate(prev.desde) + ' → ' + fmtDate(prev.hasta);

  document.getElementById('compareIngreso').innerHTML  = buildCompareCard('Ingreso en ventas', cI,    pI,    prevLabel, true);
  document.getElementById('compareGanancia').innerHTML = buildCompareCard('Ganancia neta',     cNeta, pNeta, prevLabel, true);
  document.getElementById('compareUnidades').innerHTML = buildCompareCard('Unidades vendidas', cU,    pU,    prevLabel, false);

  const prevVentas = ventasEnRango(prev.desde, prev.hasta);
  renderChart(curr, prevVentas, prev.desde, prev.hasta, dashRange.desde, dashRange.hasta);
}

function buildCompareCard(label, curr, prev, prevLabel, isMoney) {
  const val     = isMoney ? fmt(curr) : curr.toLocaleString('es-AR');
  const prevVal = isMoney ? fmt(prev) : prev.toLocaleString('es-AR');
  return `
    <div class="compare-title">${label}</div>
    <div style="margin:8px 0 4px">
      <div class="compare-current">${val}</div>
      ${deltaHtml(curr, prev)}
    </div>
    <div class="compare-prev-row">
      <div class="compare-prev-label">${prevLabel}</div>
      <div class="compare-prev-val">${prevVal}</div>
    </div>
  `;
}

function renderChart(currVentas, prevVentas, prevDesde, prevHasta, currDesde, currHasta) {
  const svgEl = document.getElementById('dashChart');
  if (!svgEl) return;
  const W = svgEl.getBoundingClientRect().width || svgEl.parentElement.clientWidth || 700;
  const H = 170;
  const padL=56, padR=20, padT=12, padB=28;
  const cW = W - padL - padR;
  const cH = H - padT - padB;

  function groupByDay(ventas, desde, hasta) {
    const map = {};
    const d0 = new Date(desde + 'T00:00:00');
    const d1 = new Date(hasta + 'T23:59:59');
    let cur = new Date(d0);
    while (cur <= d1) { map[cur.toISOString().slice(0,10)] = 0; cur.setDate(cur.getDate()+1); }
    ventas.forEach(v => { const k = v.fecha.slice(0,10); if (k in map) map[k] += v.totalIngreso; });
    return Object.values(map);
  }

  const cData = groupByDay(currVentas, currDesde, currHasta);
  const pData = groupByDay(prevVentas, prevDesde, prevHasta).slice(0, cData.length);
  const maxVal = Math.max(...cData, ...pData, 1);

  function pts(data) {
    if (!data.length) return '';
    return data.map((v,i) => {
      const x = padL + (i / Math.max(data.length-1,1)) * cW;
      const y = padT + cH - (v/maxVal)*cH;
      return x.toFixed(1)+','+y.toFixed(1);
    }).join(' ');
  }

  function area(data, fill) {
    if (data.length < 2) return '';
    const points = data.map((v,i) => ({ x: padL+(i/Math.max(data.length-1,1))*cW, y: padT+cH-(v/maxVal)*cH }));
    const line = points.map((p,i) => (i===0?'M':'L')+p.x.toFixed(1)+','+p.y.toFixed(1)).join(' ');
    const close = 'L'+points[points.length-1].x.toFixed(1)+','+(padT+cH)+' L'+padL+','+(padT+cH)+' Z';
    return `<path d="${line} ${close}" fill="${fill}" opacity="0.1"/>`;
  }

  // Y ticks
  let yAxis = '';
  for (let i=0; i<=4; i++) {
    const v = maxVal*i/4;
    const y = padT + cH - (v/maxVal)*cH;
    yAxis += `<line x1="${padL}" y1="${y.toFixed(1)}" x2="${padL+cW}" y2="${y.toFixed(1)}" stroke="#2a2a2a" stroke-width="1"/>
<text x="${(padL-8).toFixed(0)}" y="${(y+4).toFixed(1)}" text-anchor="end" fill="#888888" font-size="10" font-family="Plus Jakarta Sans,sans-serif">${fmtShort(v)}</text>`;
  }

  // X labels
  const step = Math.max(1, Math.ceil(cData.length / 8));
  const d0 = new Date(currDesde + 'T00:00:00');
  let xAxis = '';
  cData.forEach((v,i) => {
    if (i % step === 0 || i === cData.length-1) {
      const x = padL + (i/Math.max(cData.length-1,1))*cW;
      const dd = new Date(d0); dd.setDate(dd.getDate()+i);
      xAxis += `<text x="${x.toFixed(1)}" y="${H-4}" text-anchor="middle" fill="#888888" font-size="10" font-family="Plus Jakarta Sans,sans-serif">${dd.getDate()}/${dd.getMonth()+1}</text>`;
    }
  });

  const cPts = pts(cData);
  const pPts = pts(pData);

  svgEl.setAttribute('viewBox', `0 0 ${W} ${H}`);
  svgEl.innerHTML = yAxis + xAxis +
    area(pData, '#0ABAB5') + area(cData, '#078282') +
    (pPts ? `<polyline points="${pPts}" fill="none" stroke="#C8FE4E" stroke-width="1.8" stroke-dasharray="5,4" opacity="0.65" stroke-linejoin="round"/>` : '') +
    (cPts ? `<polyline points="${cPts}" fill="none" stroke="#a8d400" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>` : '');
}

function renderDashboard(c) {
  const stockBajo = state.productos.filter(p => p.cantidad>0 && p.cantidad<=3).length;
  const sinStock  = state.productos.filter(p => p.cantidad===0).length;
  c.innerHTML = `
    <div class="date-range-bar">
      <div class="date-range-label">Período</div>
      <div class="date-range-group">
        <input type="date" class="date-input" id="dashDesde" value="${dashRange.desde}" onchange="onDateChange()">
        <span class="date-separator">→</span>
        <input type="date" class="date-input" id="dashHasta" value="${dashRange.hasta}" onchange="onDateChange()">
      </div>
      <div class="preset-chips">
        <button class="chip ${dashRange.preset==='hoy'?'active':''}" data-preset="hoy"  onclick="setPreset('hoy')">Hoy</button>
        <button class="chip ${dashRange.preset==='7d'  ?'active':''}" data-preset="7d"   onclick="setPreset('7d')">7 días</button>
