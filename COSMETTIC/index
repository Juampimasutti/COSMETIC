  document.getElementById('compraBilletera').value='efectivo';
  document.getElementById('compraMonedaGroup').style.display='none';
  document.getElementById('compraTotalMerc').textContent='$0';
  document.getElementById('compraTotalFlete').textContent='$0';
  document.getElementById('compraTotalEgreso').textContent='$0';
  document.getElementById('compraNuevoCostoProm').textContent='$0';
  openModal('modalCompra');
}

function onCompraBilleteraChange() {
  const b=document.getElementById('compraBilletera').value;
  document.getElementById('compraMonedaGroup').style.display=b==='banco'?'block':'none';
}

function onCompraProductoChange() {
  const p=state.productos.find(x=>x.id===document.getElementById('compraProductoId').value);
  if(p) document.getElementById('compraCosto').value=p.costoProm;
  calcCompraTotales();
}

function calcCompraTotales() {
  const p=state.productos.find(x=>x.id===document.getElementById('compraProductoId').value);
  const cant=parseFloat(document.getElementById('compraCantidad').value)||0;
  const costo=parseFloat(document.getElementById('compraCosto').value)||0;
  const flete=parseFloat(document.getElementById('compraFlete').value)||0;
  const totalMerc=cant*costo;
  document.getElementById('compraTotalMerc').textContent=fmt(totalMerc);
  document.getElementById('compraTotalFlete').textContent=fmt(flete);
  document.getElementById('compraTotalEgreso').textContent=fmt(totalMerc+flete);
  if(p){ const np=(p.costoProm*p.cantidad+costo*cant)/(p.cantidad+cant); document.getElementById('compraNuevoCostoProm').textContent=fmt(np||0); }
}

function guardarCompra() {
  const id=document.getElementById('compraProductoId').value;
  const p=state.productos.find(x=>x.id===id);
  if(!p) return toast('Seleccioná un producto.','error');
  const cant=parseFloat(document.getElementById('compraCantidad').value)||0;
  const costo=parseFloat(document.getElementById('compraCosto').value)||0;
  const flete=parseFloat(document.getElementById('compraFlete').value)||0;
  const billetera=document.getElementById('compraBilletera').value;
  const moneda=billetera==='banco'?document.getElementById('compraMoneda').value:'ars';
  const nota=document.getElementById('compraNota').value.trim();
  if(cant<=0) return toast('La cantidad debe ser mayor a 0.','error');
  const totalMerc=cant*costo;
  const totalCaja=totalMerc+flete;
  const ncp=(p.costoProm*p.cantidad+costo*cant)/(p.cantidad+cant);
  const fecha=localISOToISO(document.getElementById('compraFecha').value);
  // Guardar compra
  state.compras.push({id:uid(),fecha,productoId:p.id,productoNombre:prodNombre(p),unidades:cant,costoUnitario:costo,flete,totalMercaderia:totalMerc,totalEgreso:totalCaja,nuevoCostoProm:ncp,nota,billetera,moneda,tipo:'compra'});
  // Actualizar stock y costo promedio
  p.cantidad+=cant; p.costoProm=ncp;
  // Egreso en caja: mercaderia + flete juntos
  state.cashflow.movimientos.push({id:uid(),tipo:'egreso',monto:totalMerc,desc:'Compra mercadería: '+prodNombre(p)+(nota?' — '+nota:''),billetera,moneda,fecha});
  if(flete>0) {
    state.cashflow.movimientos.push({id:uid(),tipo:'egreso',monto:flete,desc:'Flete compra: '+prodNombre(p)+(nota?' — '+nota:''),billetera,moneda,fecha,esFlete:true});
  }
  closeModal('modalCompra'); toast('Compra registrada.','success'); renderPage(currentPage);
}

function eliminarCompra(id) {
  if(!confirm('¿Eliminar esta compra? El stock no se revertirá automáticamente.')) return;
  state.compras=state.compras.filter(c=>c.id!==id);
  toast('Compra eliminada.'); renderPage(currentPage);
}

