let ventaItems=[];

function ventaAgregarItem(){
  // Guardar valores actuales antes de agregar
  ventaItems.forEach(item=>{
    const ep=document.getElementById('vip_'+item.id);
    const ec=document.getElementById('vic_'+item.id);
    const ev=document.getElementById('viv_'+item.id);
    if(ep) item.pid=ep.value;
    if(ec) item.cant=ec.value;
    if(ev) item.pv=ev.value;
  });
  ventaItems.push({id:uid(),pid:'',cant:'1',pv:''});
  renderVentaItems();
}

function ventaEliminarItem(iid){
  if(ventaItems.length<=1)return toast('La venta debe tener al menos un producto.','error');
  // Guardar valores actuales antes de eliminar
  ventaItems.forEach(item=>{
    const ep=document.getElementById('vip_'+item.id);
    const ec=document.getElementById('vic_'+item.id);
    const ev=document.getElementById('viv_'+item.id);
    if(ep) item.pid=ep.value;
    if(ec) item.cant=ec.value;
    if(ev) item.pv=ev.value;
  });
  ventaItems=ventaItems.filter(i=>i.id!==iid);
  renderVentaItems();
  calcVentaTotales();
}

function renderVentaItems(){
  const con=document.getElementById('ventaItems');
  if(!con)return;
  const sorted=[...state.productos].sort((a,b)=>a.categoria.localeCompare(b.categoria)||prodNombre(a).localeCompare(prodNombre(b)));
  con.innerHTML=ventaItems.map((item,idx)=>{
    const opts=sorted.map(p=>'<option value="'+p.id+'"'+(item.pid===p.id?' selected':'')+'>'+prodNombre(p)+' (stock: '+p.cantidad+')</option>').join('');
    const l0=idx===0;
    return '<div style="display:grid;grid-template-columns:1fr 80px 110px 32px;gap:8px;align-items:end;margin-bottom:8px">'
      +'<div>'+(l0?'<label class="form-label">Producto</label>':'')
      +'<select class="input input-full" id="vip_'+item.id+'" onchange="ventaItemProductoChange(\''+item.id+'\')">'
      +'<option value="">— seleccionar —</option>'+opts+'</select></div>'
      +'<div>'+(l0?'<label class="form-label">Cant.</label>':'')
      +'<input class="input input-full" id="vic_'+item.id+'" type="number" min="1" value="'+(item.cant||1)+'" oninput="calcVentaTotales()"></div>'
      +'<div>'+(l0?'<label class="form-label">Precio $</label>':'')
      +'<input class="input input-full" id="viv_'+item.id+'" type="number" min="0" placeholder="0" value="'+(item.pv||'')+'" oninput="calcVentaTotales()"></div>'
      +'<div style="'+(l0?'padding-top:20px':'')+'">'
      +'<button class="btn btn-danger" style="padding:6px 8px" onclick="ventaEliminarItem(\''+item.id+'\')">✕</button></div></div>';
  }).join('');
}

function ventaItemProductoChange(iid){
  const pid=document.getElementById('vip_'+iid).value;
  const p=state.productos.find(x=>x.id===pid);
  if(p)document.getElementById('viv_'+iid).value=p.precioVenta;
  calcVentaTotales();
}

function calcVentaTotales(){
  let tI=0,tC=0;
  ventaItems.forEach(item=>{
    const e1=document.getElementById('vip_'+item.id);
    const e2=document.getElementById('vic_'+item.id);
    const e3=document.getElementById('viv_'+item.id);
    const pid=e1?e1.value:'';
    const cant=e2?parseFloat(e2.value)||0:0;
    const pv=e3?parseFloat(e3.value)||0:0;
    const p=state.productos.find(x=>x.id===pid);
    tI+=cant*pv; tC+=p?cant*p.costoProm:0;
  });
  document.getElementById('ventaTotalIngreso').textContent=fmt(tI);
  document.getElementById('ventaTotalCosto').textContent=fmt(tC);
  document.getElementById('ventaTotalGanancia').textContent=fmt(tI-tC);
}

function guardarVenta() {
  const nota  = document.getElementById('ventaNota').value.trim();
  const medio = document.getElementById('ventaMedio').value;
  const fechaVenta = localISOToISO(document.getElementById('ventaFecha').value);
  const _vBill = (medio==='banco'||medio==='usdt') ? 'banco' : 'efectivo';
  const _vMon  = medio==='usdt' ? 'usdt' : 'ars';
  const items = [];
  for (const item of ventaItems) {
    const pid  = document.getElementById('vip_'+item.id)?.value;
    const cant = parseFloat(document.getElementById('vic_'+item.id)?.value)||0;
    const pv   = parseFloat(document.getElementById('viv_'+item.id)?.value)||0;
    const p    = state.productos.find(x=>x.id===pid);
    if (!p)      return toast('Seleccioná un producto en cada fila.','error');
    if (cant<=0) return toast('La cantidad debe ser mayor a 0.','error');
    if (cant>p.cantidad) return toast('Stock insuficiente para '+prodNombre(p)+'. Disponible: '+p.cantidad,'error');
    items.push({p, cant, pv});
  }
  const ids = items.map(i=>i.p.id);
  if (new Set(ids).size !== ids.length) return toast('Hay productos repetidos. Sumálos en una sola fila.','error');
  let totalIng=0, totalCos=0;
  items.forEach(function(obj) {
    var p=obj.p, cant=obj.cant, pv=obj.pv;
    var ing=cant*pv, cos=cant*p.costoProm;
    totalIng+=ing; totalCos+=cos;
    state.ventas.push({id:uid(), fecha:fechaVenta, productoId:p.id, productoNombre:prodNombre(p),
      unidades:cant, pvUnitario:pv, costoUnitario:p.costoProm,
      totalIngreso:ing, totalCosto:cos, totalGanancia:ing-cos,
      nota:nota, medio:medio, descuentoPct:0});
    p.cantidad-=cant;
  });
  var desc='Venta'+(items.length>1?' ('+items.length+' productos)':': '+prodNombre(items[0].p))+(nota?' — '+nota:'');
  state.cashflow.movimientos.push({id:uid(), tipo:'ingreso', monto:totalIng, desc:desc, billetera:_vBill, moneda:_vMon, fecha:fechaVenta});
  closeModal('modalVenta');
  toast('Venta registrada — '+items.length+(items.length===1?' producto':' productos')+'.','success');
  renderPage(currentPage);
}
function eliminarVenta(id) {
  if(!confirm('¿Eliminar esta venta? El stock no se revertirá automáticamente.')) return;
  state.ventas=state.ventas.filter(v=>v.id!==id);
  toast('Venta eliminada.'); renderPage(currentPage);
}

