function exportarDatos() {
  const backup={version:'1.0',exportedAt:new Date().toISOString(),productos:state.productos,ventas:state.ventas,compras:state.compras,cashflow:state.cashflow,categorias:state.categorias,gastos:state.gastos,categoriasGastos:state.categoriasGastos};
  const blob=new Blob([JSON.stringify(backup,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a'); a.href=url;
  a.download='cosmeticos_backup_'+new Date().toISOString().slice(0,10)+'.json'; a.click();
  URL.revokeObjectURL(url); toast('Backup exportado.','success');
}

function importarDatos(event) {
  const file=event.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=e=>{
    try {
      const data=JSON.parse(e.target.result);
      if(!confirm('Importar datos'+(data.exportedAt?' del '+fmtDate(data.exportedAt):'')+'\nEsto reemplazará todos los datos actuales.')) return;
      if(data.productos) state.productos=data.productos.map(p=>({id:p.id||uid(),categoria:p.categoria||'Otro',marca:p.marca||'',nombre:p.nombre||p.sabor||'',variante:p.variante||'',cantidad:p.cantidad||0,costoProm:p.costoProm||0,precioVenta:p.precioVenta||0,descuentoPct:p.descuentoPct||0}));
      if(data.ventas) state.ventas=data.ventas.map(v=>({id:v.id||uid(),fecha:v.fecha,productoId:v.productoId||'',productoNombre:v.productoNombre||(v.items&&v.items[0]?v.items[0].marca+' '+v.items[0].sabor:'—'),unidades:v.unidades||0,pvUnitario:v.pvUnitario||(v.items&&v.items[0]?v.items[0].pv:0),costoUnitario:v.costoUnitario||(v.items&&v.items[0]?v.items[0].costo:0),totalIngreso:v.totalIngreso||0,totalCosto:v.totalCosto||0,totalGanancia:v.totalGanancia||0,nota:v.nota||'',descuentoPct:0}));
      if(data.compras) state.compras=data.compras;
      if(data.cashflow) state.cashflow=data.cashflow;
      if(data.categorias) state.categorias=[...new Set([...state.categorias,...data.categorias])];
      if(data.gastos) state.gastos=data.gastos;
      if(data.categoriasGastos) state.categoriasGastos=[...new Set([...state.categoriasGastos,...data.categoriasGastos])];
      toast('Datos importados correctamente.','success'); renderPage(currentPage);
    } catch { toast('Error al importar. Verificá que sea un JSON válido.','error'); }
  };
  reader.readAsText(file); event.target.value='';
}


