let cfFiltroOrigen = '';

function cfOrigenLabel(m) {
  if (m.esGasto) return 'gasto';
  if (m.esFlete) return 'flete';
  if (m.desc && m.desc.startsWith('Venta:')) return 'venta';
  if (m.desc && m.desc.startsWith('Compra')) return 'compra';
  return 'manual';
}

function cfOrigenColor(origen) {
  const bg    = {venta:'rgba(200,254,78,0.1)',compra:'rgba(255,100,100,0.1)',gasto:'rgba(240,168,48,0.12)',flete:'rgba(100,180,255,0.1)',manual:'rgba(255,255,255,0.06)'};
  const color = {venta:'var(--primary)',compra:'var(--red)',gasto:'#f0a830',flete:'#64b4ff',manual:'var(--text3)'};
  return {bg:bg[origen]||bg.manual, color:color[origen]||color.manual};
}

function cfSaldo(billetera, moneda) {
  return state.cashflow.movimientos
    .filter(m => m.billetera===billetera && (moneda ? m.moneda===moneda : true))
    .reduce((s,m) => m.tipo==='ingreso' ? s+m.monto : s-m.monto, 0);
}

function cfMedioLabel(m) {
  if (m.billetera==='efectivo') return 'Efectivo';
  if (m.billetera==='banco' && m.moneda==='usdt') return 'Banco USDT';
  return 'Banco $';
}

