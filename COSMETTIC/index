function poblarSelectProductos(selectId) {
  const el = document.getElementById(selectId);
  if (!el) return;
  const sorted = [...state.productos].sort((a,b) => a.categoria.localeCompare(b.categoria) || prodNombre(a).localeCompare(prodNombre(b)));
  let lc = '';
  el.innerHTML = '<option value="">— seleccionar —</option>';
  sorted.forEach(p => {
    if (p.categoria !== lc) { const og = document.createElement('optgroup'); og.label = p.categoria; el.appendChild(og); lc = p.categoria; }
    const opt = document.createElement('option'); opt.value = p.id; opt.textContent = prodNombre(p) + ' (stock: ' + p.cantidad + ')'; el.appendChild(opt);
  });
}

function poblarSelectCategorias(selectId, sel='') {
  const el = document.getElementById(selectId);
  el.innerHTML = '<option value="">— seleccionar —</option>' +
    state.categorias.map(c=>`<option value="${c}" ${c===sel?'selected':''}>${c}</option>`).join('');
}

function toggleNuevaCat() { document.getElementById('nuevaCatBox').classList.toggle('hidden'); }

function guardarProducto() {
  const id = document.getElementById('prodId').value;
  let cat = document.getElementById('prodCategoria').value;
  const nc = document.getElementById('prodNuevaCat').value.trim();
  if (nc) { cat=nc; if(!state.categorias.includes(cat)) state.categorias.push(cat); }
  const marca=document.getElementById('prodMarca').value.trim();
  const nombre=document.getElementById('prodNombre').value.trim();
  const variante=document.getElementById('prodVariante').value.trim();
  const costoProm=parseFloat(document.getElementById('prodCosto').value)||0;
  const precioVenta=parseFloat(document.getElementById('prodPrecio').value)||0;
  if(!cat||!marca||!nombre) return toast('Completá los campos obligatorios.','error');
  if(id) {
    const p=state.productos.find(x=>x.id===id);
    Object.assign(p,{categoria:cat,marca,nombre,variante,costoProm,precioVenta});
    toast('Producto actualizado.');
  } else {
    const cantidad=parseFloat(document.getElementById('prodCantidad').value)||0;
